═══════════════════════════════════════════════════════\n# THEORETICAL CONSTANTS (H7 Framework)\n# ══════════════════════════════════════════════════════════════════════════════\n\nn = 1\nPHI = (1 + math.sqrt(5)) / 2\nPARITY = math.cos(np.pi * n)\nPSI_1 = abs(math.cos(math.pi * PHI * n))\n\nberry_phase = 2 * math.pi  \nDRIFT_072 = 7 - berry_phase      # ~ 0.7168\nEPSILON = PSI_1 / 2              # ~ 0.1812 (Threshold of vacuum)\n\n# Real Metaplectic Weights (71.7 - 28.3 - 1)\nW_SYMP = DRIFT_072               # Conservation/Inertia (Base)\nW_METR = 1.0 - DRIFT_072 - 0.01  # Dissipation/Entropy\nW_VAC  = 0.01\n\n# ══════════════════════════════════════════════════════════════════════════════\n# BASE FUNCTIONS AND GENERATORS\n# ══════════════════════════════════════════════════════════════════════════════\n\n@kbench.task(name=\"double distance-five tracks\", description=\"Basic hard-rule LLM check\")\ndef double_distance(llm) -> None:\n    # A. Prompt the model\n    response: str = llm.prompt(\"What is a light-year?\")\n\n    # B. Simple Check (Hard Rule)\n    kbench.assertions.assert_in(\"distance\", response.lower())\n\n    # C. Optional Advanced Check (LLM Judge)\n    assessment = kbench.assertions.assess_response_with_judge(\n        response_text=response,\n        judge_llm=kbench.judge_llm,\n        criteria=[\n            \"The answer must clarify the concept, give examples, and be direct.\",\n            \"The answer should mention astronomical distances.\",\n        ]\n    )\n\n@kbench.task(name=\"generate new basis\", description=\"Data Holographic Z_7 generator\")\ndef generate_basis(N=128, delta=1.0):\n    B_obj = np.zeros((7, N))  # objective parameter\n    B_ref = np.zeros((7, N))  # reference, the info known\n    for d in range(7):\n        phi_d = PHI ** (d + 1)\n        for idx in range(N):\n            n_val = idx + 1\n            B_obj[d, idx] = math.cos(math.pi * phi_d * n_val + delta)\n            B_ref[d, idx] = math.cos(math.pi * phi_d * n_val - delta)\n    return B_obj, B_ref\n\ndef ternary_collapse(H: np.ndarray, thresh: float) -> np.ndarray:\n    T = np.zeros_like(H)\n    T[H > thresh] = 1\n    T[H < -thresh] = -1\n    return T\n\n# ══════════════════════════════════════════════════════════════════════════════\n# TEXT ANALYZERS\n# ══════════════════════════════════════════════════════════════════════════════\n\nclass ResponseConsistencyAnalyzer:\n    \"\"\"Analyze response consistency to detect learning vs memorization\"\"\"\n    \n    def __init__(self):\n        self.vectorizer = TfidfVectorizer(stop_words='english', max_features=100)\n        self.responses = []\n    \n    def add_response(self, response_text: str):\n        self.responses.append(response_text)\n    \n    def analyze_semantic_coherence(self) -> float:\n        if len(self.responses) < 2:\n            return 0.0\n        try:\n            tfidf_matrix = self.vectorizer.fit_transform(self.responses).toarray()\n            similarities = []\n            for i in range(len(tfidf_matrix)):\n                for j in range(i + 1, len(tfidf_matrix)):\n                    # Validate to avoid division by zero in cosine distance\n                    if np.all(tfidf_matrix[i] == 0) or np.all(tfidf_matrix[j] == 0):\n                        continue\n                    sim = 1 - cosine(tfidf_matrix[i], tfidf_matrix[j])\n                    similarities.append(sim)\n            return float(np.mean(similarities)) if similarities else 0.0\n        except Exception as e:\n            logger.error(f\"Error in analyze_semantic_coherence: {e}\")\n            return 0.0\n\n    def analyze_keyword_consistency(self, keyword_lists: List[List[str]]) -> float:\n        if len(keyword_lists) < 2:\n            return 0.0\n        \n        all_keywords = set()\n        for kw_list in keyword_lists:\n            all_keywords.update(kw_list)\n        \n        if not all_keywords:\n            return 0.0\n        \n        keyword_frequencies = {}\n        for kw_list in keyword_lists:\n            for kw in kw_list:\n                keyword_frequencies[kw] = keyword_frequencies.get(kw, 0) + 1\n        \n        consistent_keywords = sum(\n            1 for freq in keyword_frequencies.values()\n            if freq > len(keyword_lists) * 0.5\n        )\n        return consistent_keywords / len(all_keywords)\n    \n    def analyze_response_variability(self) -> float:\n        if len(self.responses) < 2:\n            return 0.0\n        \n        lengths = [len(r.split()) for r in self.responses]\n        mean_length = np.mean(lengths)\n        std_length = np.std(lengths)\n        \n        if mean_length > 0:\n            cv = std_length / mean_length\n            return min(cv, 1.0)\n        return 0.0\n\n# ══════════════════════════════════════════════════════════════════════════════\n# DOUBLE DISTANCE LEARNING DETECTOR (H7 Integration)\n# ══════════════════════════════════════════════════════════════════════════════\n\nclass DoubleLearningDetector:\n    def __init__(self, alpha: float = 0.5):\n        self.alpha = alpha\n        self.consistency_analyzer = ResponseConsistencyAnalyzer()\n    \n    def measure_learning_probability(self,\n                                    responses: List[str],\n                                    prompt_types: List[str],\n                                    keywords_per_response: List[List[str]],\n                                    judge_scores: Optional[List[float]] = None) -> ConsistencyMetrics:\n        \n        for resp in responses:\n            self.consistency_analyzer.add_response(resp)\n        \n        semantic_coherence = self.consistency_analyzer.analyze_semantic_coherence()\n        keyword_consistency = self.consistency_analyzer.analyze_keyword_consistency(keywords_per_response)\n        response_variability = self.consistency_analyzer.analyze_response_variability()\n        \n        memorization_risk = self._calculate_memorization_risk(\n            semantic_coherence, keyword_consistency, response_variability, prompt_types, judge_scores\n        )\n        \n        learning_signal = 1.0 - memorization_risk\n        \n        return ConsistencyMetrics(\n            semantic_coherence=semantic_coherence,\n            keyword_consistency=keyword_consistency,\n            response_variability=response_variability,\n            memorization_risk=memorization_risk,\n            learning_signal=learning_signal\n        )\n    \n    def _calculate_memorization_risk(self,\n                                    semantic_coherence: float,\n                                    keyword_consistency: float,\n                                    response_variability: float,\n                                    prompt_types: List[str],\n                                    judge_scores: Optional[List[float]] = None) -> float:\n        \n        base_risk = (semantic_coherence * 0.4) + (keyword_consistency * 0.4)\n        variability_adjustment = (1.0 - response_variability) * 0.2\n        total_risk = min(base_risk + variability_adjustment, 1.0)\n        \n        if judge_scores and prompt_types:\n            extrapolation_indices = [i for i, pt in enumerate(prompt_types) if pt == \"extrapolation\"]\n            if extrapolation_indices:\n                extrapolation_scores = [judge_scores[i] for i in extrapolation_indices]\n                extrapolation_mean = np.mean(extrapolation_scores)\n                if extrapolation_mean < 0.5:\n                    total_risk = min(total_risk + 0.2, 1.0)\n        \n        return total_risk\n\n# ══════════════════════════════════════════════════════════════════════════════\n# KBENCH TASK\n# ══════════════════════════════════════════════════════════════════════════════\n\n@kbench.task(\n    name=\"double_distance_learning_detection\",\n    description=\"Does the LLM learn or memorize? Detect via semantic consistency and prompt variations.\"\n)\ndef double_distance_learning_detection(llm) -> dict:    \n    class MockVariant:\n        def __init__(self, name, template, keywords_expected, p_type):\n            self.name = name\n            self.template = template\n            self.keywords_expected = keywords_expected\n            self.type = p_type\n\n    prompt_variants = [\n        MockVariant(\"standard\", \"What is a light-year?\", [\"distance\", \"light\", \"year\"], \"standard\"),\n        MockVariant(\"interpolation\", \"Explain a light-year to a 10-year-old.\", [\"distance\", \"space\"], \"interpolation\"),\n        MockVariant(\"extrapolation\", \"If a ship travels at half the speed of light, how long does it take to cover a light-year?\", [\"two\", \"years\", \"distance\"], \"extrapolation\")\n    ]\n\n    responses_dict = {}\n    analyses = []\n    \n    logger.info(f\"Testing LLM on {len(prompt_variants)} prompt variations...\")\n    \n    for variant in prompt_variants:\n        try:\n            response = llm.prompt(variant.template)\n            responses_dict[variant.name] = response\n            \n            response_lower = response.lower()\n            keywords_found = [kw for kw in variant.keywords_expected if kw.lower() in response_lower]\n            keyword_coverage = len(keywords_found) / len(variant.keywords_expected) if variant.keywords_expected else 0.0\n            \n            analysis = ResponseAnalysis(\n                prompt_variant=variant.name,\n                response_text=response,\n                response_hash=hashlib.md5(response.encode()).hexdigest()[:8],\n                keywords_found=keywords_found,\n                keyword_coverage=keyword_coverage,\n                response_length=len(response.split())\n            )\n            analyses.append(analysis)\n            logger.info(f\"  [{variant.name}] {analysis.response_length} words, {len(keywords_found)}/{len(variant.keywords_expected)} keywords\")\n        \n        except Exception as e:\n            logger.error(f\"Error on variant '{variant.name}': {e}\")\n\n    # Validation\n    all_keywords_found = set()\n    for analysis in analyses:\n        all_keywords_found.update(analysis.keywords_found)\n    \n    core_keywords = {\"distance\", \"light\", \"space\", \"astronomy\", \"year\"}\n    keywords_in_responses = core_keywords & all_keywords_found\n    \n    try:\n        kbench.assertions.assert_greater_equal(len(keywords_in_responses), 2)\n        logger.info(f\"✓ Hard check passed: Found {len(keywords_in_responses)} core keywords\")\n    except Exception as e:\n        logger.error(f\"✗ Hard check failed: {e}\")\n\n    # Judge\n    judge_scores = []\n    for i, analysis in enumerate(analyses):\n        try:\n            assessment = kbench.assertions.assess_response_with_judge(\n                response_text=analysis.response_text,\n                judge_llm=kbench.judge_llm,\n                criteria=[\"Clear definition.\", \"Concrete examples.\", \"Direct answer.\"]\n            )\n            score = assessment.get('overall_score', 1.0) if isinstance(assessment, dict) else (1.0 if assessment else 0.0)\n            judge_scores.append(score)\n            analysis.semantic_score = score\n            analysis.judge_assessment = assessment\n        except Exception as e:\n            logger.warning(f\"Judge assessment failed for [{analysis.prompt_variant}]: {e}\")\n            judge_scores.append(0.5)\n\n    # Metrics\n    detector = DoubleLearningDetector(alpha=0.5)\n    consistency_metrics = detector.measure_learning_probability(\n        responses=[a.response_text for a in analyses],\n        prompt_types=[v.type for v in prompt_variants],\n        keywords_per_response=[a.keywords_found for a in analyses],\n        judge_scores=judge_scores\n    )\n    \n    # Report\n    report = {\n        \"test_name\": \"Double Distance Learning Detection\",\n        \"total_variants_tested\": len(analyses),\n        \"average_response_length\": float(np.mean([a.response_length for a in analyses])) if analyses else 0.0,\n        \"average_judge_score\": float(np.mean(judge_scores)) if judge_scores else 0.0,\n        \"consistency_metrics\": {\n            \"semantic_coherence\": float(consistency_metrics.semantic_coherence),\n            \"keyword_consistency\": float(consistency_metrics.keyword_consistency),\n            \"response_variability\": float(consistency_metrics.response_variability),\n            \"memorization_risk\": float(consistency_metrics.memorization_risk),\n            \"learning_signal\": float(consistency_metrics.learning_signal),\n        },\n        \"interpretation\": _interpret_metrics(consistency_metrics),\n    }\n    \n    logger.info(\"\\n\" + json.dumps(report, indent=2))\n    return report\n\ndef _interpret_metrics(metrics: ConsistencyMetrics) -> Dict[str, str]:\n    learning_level = (\n        \"Strong Learning\" if metrics.learning_signal > 0.7\n        else \"Moderate Learning\" if metrics.learning_signal > 0.5\n        else \"Weak Learning\" if metrics.learning_signal > 0.3\n        else \"Likely Memorization\"\n    )\n    return {\"learning_assessment\": learning_level}\n\nif __name__ == \"__main__\":\n    double_distance.run(kbench.llm)\n\n# Note: To test a specific model locally, you can use the dictionary lookup:\ndouble_distance.run(kbench.llms[\"google/gemini-2.5-flash\"])\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-29T23:54:35.145498Z","iopub.execute_input":"2026-03-29T23:54:35.145867Z","iopub.status.idle":"2026-03-29T23:55:02.541747Z","shell.execute_reply.started":"2026-03-29T23:54:35.145835Z","shell.execute_reply":"2026-03-29T23:55:02.540685Z"}},"outputs":[{"output_type":"display_data","data":{"text/html":"<script type=\"esms-options\">{\"shimMode\": true}</script><style>*[data-root-id],\n*[data-root-id] > * {\n  box-sizing: border-box;\n  font-family: var(--jp-ui-font-family);\n  font-size: var(--jp-ui-font-size1);\n  color: var(--vscode-editor-foreground, var(--jp-ui-font-color1));\n}\n\n/* Override VSCode background color